# ─────────────────────────────────────────
# FightMind AI — Java Spring Boot Backend
# Copy this file to .env and fill in values
# ─────────────────────────────────────────

# ── Database (local Docker PostgreSQL) ────
DB_URL=jdbc:postgresql://localhost:5432/fightmind
DB_USERNAME=admin
DB_PASSWORD=secret

# ── Redis ─────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redispass
# REDIS_SSL=true # (Required for Upstash/Production)

# ── JWT Secret (min 32 characters) ────────
JWT_SECRET=your_super_secret_jwt_key_min_32_chars_here_change_this
JWT_EXPIRY_MS=86400000

# ── Admin Account ─────────────────────────
# Username is always: fightmind_admin
# Password is loaded here and BCrypt-hashed at runtime by AdminSeeder
# NEVER commit the real password to git
ADMIN_PASSWORD=your_admin_password_here

# ── Google OAuth2 ─────────────────────────
# Get these from https://console.cloud.google.com → APIs → Credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# ── Python AI Service ─────────────────────
PYTHON_SERVICE_URL=http://localhost:8000

# ── Cloudinary (image uploads) ────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ── Environment ───────────────────────────
ENV=development

# ── Logging ───────────────────────────────
# LOG_PATH=/tmp # (Required for Docker/Render to avoid file permission errors)

# ── Frontend (CORS & OAuth2) ──────────────
FRONTEND_URL=http://localhost:5173
APP_OAUTH2_REDIRECT_URI=http://localhost:5173/oauth2/redirect
